<div class="photo">
  <img src="<%= @preview_url %>" alt="Shared memory" />
</div>

<!-- Top-of-page brand badge so receivers know what app this is -->
<div class="brand-badge">
  <span class="brand-mark">●</span>
  <span class="brand-name">Memory Tunnel</span>
</div>

<div class="card">
  <p class="sender"><%= @sender.display_name %> shared a memory with you on <strong>Memory Tunnel</strong></p>
  <h1 class="headline">For the people who matter most</h1>
  <a href="#" class="cta" onclick="openApp(); return false;">
    Open in Memory Tunnel
  </a>
  <p class="sub">Free app · No ads · Just the two of you</p>
</div>
